	pages = {95--104},
	file = {Full Text PDF:C\:\\Users\\Edvaldo GR\\Zotero\\storage\\H3TZ4GPD\\Arraiano (2018) - The Impact of Socially Responsible Investing in European Markets Evidence of the Global Financial C.pdf:application/pdf},
