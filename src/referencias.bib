	pages = {42609--42619},
	annote = {Cited by: 0; All Open Access; Gold Open Access},
	annote = {Cited by: 0; All Open Access; Gold Open Access},
	file = {Full Text PDF:C\:\\Users\\Edvaldo GR\\Zotero\\storage\\4TIA4X2P\\Peng (2026) - Systematic Risk Effects of ESG Screening in Portfolio Construction.pdf:application/pdf},
