	keywords = {ESG investment, International robustness, Performance},
	pages = {51--62},
	file = {PDF:C\:\\Users\\Edvaldo GR\\Zotero\\storage\\FTLCHTPS\\Auer e Schuhmacher (2016) - Do socially (ir)responsible investments pay New evidence from international ESG data.pdf:application/pdf},
}

