	pages = {211 -- 230},
	annote = {Cited by: 16; All Open Access; Bronze Open Access; Green Open Access},
	file = {Full Text PDF:C\:\\Users\\Edvaldo GR\\Zotero\\storage\\MSW64EXN\\Jin e Zhang (2023) - The Stock Performance of Green Bond Issuers During COVID-19 Pandemic The Case of China.pdf:application/pdf},
}

@inproceedings{zhang_empirical_2026,
	title = {An {Empirical} {Study} on {ESG} {Multi}-{Factor} {Models} {Based} on {XGBoost} and {Other} {Boosting} {Algorithms}},
	isbn = {979-8-4007-1951-6},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105030330046&doi=10.1145%2F3785706.3785758&partnerID=40&md5=7d6763eb12a918beaa3aca59f9719dac},
	doi = {10.1145/3785706.3785758},
	abstract = {With the growing emphasis on sustainable development in global capital markets, environmental (E), social (S), and governance (G) factors have gradually become critical references for investment decisions. However, traditional linear multi-factor models face limitations in handling nonlinear relationships and high-dimensional factors, making it difficult to fully reveal the impact of ESG factors on asset returns and risk. This study constructs a multi-factor model that integrates ESG factors with traditional financial factors, based on XGBoost and other Boosting algorithms, and conducts empirical analysis using financial and market data of Chinese A-share listed companies from 2015 to 2024, together with the Wind ESG database. The research first standardizes and quantifies ESG factors, then applies Boosting algorithms for factor selection and weight optimization, and compares the results with traditional regression models. Empirical findings indicate that, compared with traditional linear multi-factor regression models, XGBoost and its variants perform better in predicting excess stock returns, improving risk-adjusted returns, and capturing nonlinear factor relationships. Among the ESG dimensions, environmental and governance factors contribute more significantly to explanatory power. Further robustness checks show that the model maintains strong applicability across different market stages and industry sectors. This study not only validates the effectiveness of ESG factors in the Chinese capital market but also provides practical insights for investment institutions applying machine learning to build intelligent and multidimensional investment strategies. © 2025 Copyright held by the owner/author(s).},
	language = {English},
	booktitle = {Proceedings of 2025 2nd {International} {Conference} on {Digital} {Economy} and {Computer} {Science}, {DECS} 2025},
	publisher = {Association for Computing Machinery, Inc},
	author = {Zhang, Zhichao},
	year = {2026},
	note = {Type: Conference paper},
	keywords = {Multi-factor model, Financial markets, Artificial intelligence, ESG, Regression analysis, Sustainable development, Commerce, Electronic trading, Investments, Boosting algorithm, Empirical studies, Factor model, Learning algorithms, Learning systems, Machine-learning, Model-based OPC, Multi-factor, Regression modelling, Xgboost},
	pages = {326 -- 332},
	annote = {Cited by: 0; Conference name: 2025 2nd International Conference on Digital Economy and Computer Science, DECS 2025; Conference sponsors: ; Conference code: 216832; Conference date: 17 October 2025 through 19 October 2025; All Open Access; Gold Open Access},
