	annote = {Cited by: 21; All Open Access; Gold Open Access; Green Open Access},
	file = {Full Text PDF:C\:\\Users\\Edvaldo GR\\Zotero\\storage\\CVTL4DB2\\Goncalves et al. (2021) - Risk and Performance of European Green and Conventional Funds.pdf:application/pdf},
}

@article{sandu_effect_2024,
	address = {BOGUMILA ZUGA 32A, WARSAW, MAZOVIA, POLAND},
	title = {The {Effect} of {ESG} {Scores} on {Portfolio} {Performance}. {Evidence} from {Europe}},
	volume = {18},
	issn = {2502-0226},
	doi = {10.2478/picbe-2024-0038},
	abstract = {The purpose of this study is to examine the performance of eight portfolios constructed based on environmental, social and governance scores. The main question I explore is whether portfolios that integrate ESG values generate a significant additional return. The sample consists of 1095 European stocks from 23 countries, and the period analyzed is 2021-2022. To form portfolios, all stocks are first ranked according to one-year lagged ESG scores (Total ESG score, Environmental score, Social score and Governance score) in a decreasing way. Then 10\% of the highest-scoring stocks are included in the Top portfolio, while 10\% of the lowest-scoring stocks are included in the Bottom portfolio. Portfolio evaluation was performed using two techniques: CAPM and Fama French five-factor regression. In addition, the Sharpe ratios of the portfolios have been calculated. The Sharpe ratio is positive for the top portfolio, showing that investors are compensated more per unit of risk. The Top Environmental portfolio is found to be the best performer for positive values. In contrast, the Sharpe ratio is negative for the Bottom portfolios. This means that these portfolios underperform the risk-free rate. The CAPM results show that all portfolios using ESG-based scores underperformed the market. The results of the Fama-French five-factor model are similar to those of the CAPM. The general findings of this study indicate that using ESG-based scores in the selection investment process does not add a significant additional return. These findings provide additional evidence to the literature on the relationship between ESG and portfolio performance in the recent European context.},
	language = {English},
	number = {1},
	journal = {PROCEEDINGS OF THE INTERNATIONAL CONFERENCE ON BUSINESS EXCELLENCE},
	publisher = {SCIENDO},
	author = {Sandu, Diana-Mihaela},
	month = jun,
	year = {2024},
	note = {Type: Proceedings Paper},
	keywords = {Sharpe ratio, CAPM, portfolio performance, ESG, Fama-French five-factor model, Europe},
	pages = {442--450},
	annote = {18th International Conference on Business Excellence (ICBE) - Smart Solutions for a Sustainable Future, Bucharest, ROMANIA, MAR 21-23, 2024},
	file = {Full Text PDF:C\:\\Users\\Edvaldo GR\\Zotero\\storage\\I2N2GMFP\\Sandu (2024) - The Effect of ESG Scores on Portfolio Performance. Evidence from Europe.pdf:application/pdf},
}

@article{peng_systematic_2026,
	address = {445 HOES LANE, PISCATAWAY, NJ 08855-4141 USA},
	title = {Systematic {Risk} {Effects} of {ESG} {Screening} in {Portfolio} {Construction}},
	volume = {14},
	issn = {2169-3536},
	doi = {10.1109/ACCESS.2026.3674731},
	abstract = {This study investigates the systematic risk effects of ESG screening in portfolio construction, using a quantitative, data-driven framework. Based on Taiwanese constituents of the Dow Jones Sustainability World Index, we examine how ESG screening reshapes portfolio-level risk structure without generating abnormal returns. Annual portfolios are constructed using a maximum Sharpe ratio optimization and evaluated through rolling out-of-sample backtests from 2022 to 2025, with the Taiwan 50 ETF serving as the market benchmark. Empirical results show that ESG-screened portfolios do not exhibit abnormal return performance relative to the market. In contrast, they demonstrate a substantially lower risk profile, characterized by significantly reduced market exposure and lower return variance. These findings remain robust under alternative asset pricing specifications, including the Fama-French three and four-factor models. Overall, the results indicate that ESG screening primarily operates through a systematic risk-structuring mechanism rather than return enhancement, enabling portfolio risk reduction while preserving market-comparable returns.},
	language = {English},
	journal = {IEEE ACCESS},
	publisher = {IEEE-INST ELECTRICAL ELECTRONICS ENGINEERS INC},
	author = {Peng, Chi-Yao},
	year = {2026},
	note = {Type: Article},
